{
  "Logging": {
    "LogLevel": {
      "Microsoft.Agents.Hosting.AspNetCore.CloudAdapter": "Debug",
      "Microsoft.Agents.Authentication.Msal.MsalAuth": "Debug",
      "Microsoft.AspNetCore.Authentication.JwtBearer": "Debug"
    }
  },

  "TokenValidation": {
    "Audiences": [ "00000000-0000-0000-0000-000000000000" ],
    "TenantId": "00000000-0000-0000-0000-000000000000"
  },

  "Connections": {
    "ServiceConnection": {
      "Settings": {
        "AuthType": "FederatedCredentials",
        "ClientId": "00000000-0000-0000-0000-000000000000",
        "AuthorityEndpoint": "https://login.microsoftonline.com/00000000-0000-0000-0000-000000000000",
        "FederatedClientId": "00000000-0000-0000-0000-000000000000",
        "Scopes": [ "https://api.botframework.com/.default" ]
      }
    }
  },

  "ConnectionsMap": [
    {
      "ServiceUrl": "*",
      "Connection": "ServiceConnection"
    }
  ],

  "RateLimit": {
    "PermitLimit": 60,
    "IntervalInSeconds": 60
  }
}
