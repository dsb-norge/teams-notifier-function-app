{
  "_comment": "Static portions of app requirements. Values here are stable across feature development and hard to extract from code. Code-derived values (queues, routes, versions, required_role, messaging_endpoint) are added by generate-requirements.sh.",

  "function_app_required_app_settings": [
    "ApiAppId",
    "APPLICATIONINSIGHTS_CONNECTION_STRING",
    "AzureWebJobsStorage__blobServiceUri",
    "AzureWebJobsStorage__clientId",
    "AzureWebJobsStorage__credential",
    "AzureWebJobsStorage__queueServiceUri",
    "AzureWebJobsStorage__tableServiceUri",
    "BotAppId",
    "PoisonAlertAlias",
    "StorageAccountName",
    "TenantId"
  ],

  "bot_auth_settings": {
    "platform_enabled": true,
    "require_authentication": false,
    "unauthenticated_action": "AllowAnonymous",
    "identity_provider": "azureActiveDirectory"
  },

  "bot_service": {
    "type": "SingleTenant"
  },

  "teams_app_configuration": {
    "scopes": ["team", "personal", "groupChat"],
    "is_notification_only": false,
    "supports_files": false,
    "supports_channel_features": "tier1"
  },

  "teams_app_command_lists": [
    {
      "scopes": ["team"],
      "commands": [
        { "title": "checkin", "description": "Get bot health status" },
        { "title": "set-alias", "description": "Create alias for this channel" },
        { "title": "create-alias", "description": "Interactive alias creation form" },
        { "title": "remove-alias", "description": "Remove an alias" },
        { "title": "list-aliases", "description": "Show all aliases" },
        { "title": "delete-post", "description": "Delete a bot message (reply to it)" },
        { "title": "setup-guide", "description": "API authentication setup instructions" },
        { "title": "queue-status", "description": "Show queue message counts" },
        { "title": "queue-peek", "description": "Peek poison queue messages" },
        { "title": "queue-retry", "description": "Retry poison messages" }
      ]
    },
    {
      "scopes": ["personal"],
      "commands": [
        { "title": "checkin", "description": "Get bot health status" },
        { "title": "set-alias", "description": "Create alias for this chat" },
        { "title": "create-alias", "description": "Interactive alias creation form" },
        { "title": "remove-alias", "description": "Remove an alias" },
        { "title": "list-aliases", "description": "Show all aliases" },
        { "title": "setup-guide", "description": "API authentication setup instructions" },
        { "title": "queue-status", "description": "Show queue message counts" },
        { "title": "queue-peek", "description": "Peek poison queue messages" }
      ]
    },
    {
      "scopes": ["groupChat"],
      "commands": [
        { "title": "checkin", "description": "Get bot health status" },
        { "title": "set-alias", "description": "Create alias for this chat" },
        { "title": "create-alias", "description": "Interactive alias creation form" },
        { "title": "remove-alias", "description": "Remove an alias" },
        { "title": "list-aliases", "description": "Show all aliases" },
        { "title": "setup-guide", "description": "API authentication setup instructions" }
      ]
    }
  ]
}
